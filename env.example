# === REQUIRED: AI ===
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# === REQUIRED: Vector Store ===
PINECONE_API_KEY=pcsk_your-key-here
PINECONE_INDEX_NAME=greenlight-docs

# === REQUIRED: Embeddings ===
VOYAGE_API_KEY=pa-your-key-here

# === Google Chat ===
GOOGLE_SERVICE_ACCOUNT_FILE=google-chat-bot-key.json

# === Email Newsletter Poller ===
# Gmail account Beacon polls for DOB / NYC.gov newsletters (Google Workspace domain).
BEACON_EMAIL=beacon@greenlightexpediting.com
# Comma-separated From addresses to ingest. Must include newsletters.nyc.gov —
# that's the real sender of the "My NYC.gov News" / Buildings News Update digests.
# Add manny@greenlightexpediting.com (or whoever forwards) to keep ingesting forwards.
EMAIL_SENDER_FILTERS=noreply@newsletters.nyc.gov,no-reply@newsletters.nyc.gov,noreply@buildings.nyc.gov,no-reply@buildings.nyc.gov,buildings@nyc.gov,manny@greenlightexpediting.com
# How often to poll, in seconds (default 3600 = 1 hour)
EMAIL_POLL_INTERVAL=3600

# === Content Scheduler ===
# Background cron: auto-generates content candidates from team questions and
# saves them to Supabase, where Ordino's /content notification bell surfaces
# new ones for review. (Notification is in the Ordino UI, not chat.)
CONTENT_SCHED_INTERVAL=86400          # seconds between runs (default daily)
CONTENT_AUTO_GENERATE=true            # master on/off switch

# === Bot Settings ===
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=1500
CLAUDE_TEMPERATURE=0.3

# === RAG Settings ===
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.5

# === Server ===
PORT=8080
DEBUG=false
LOG_LEVEL=INFO
